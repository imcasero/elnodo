---
---

<section id="contacto" class="section-padding relative overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0">
    <div class="absolute bottom-0 left-1/4 w-96 h-96 bg-primary/10 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left content -->
      <div>
        <span class="font-mono text-primary text-sm mb-4 block">// Contacto</span>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
          Hagamos algo
          <span class="text-primary text-glow">increíble</span>
          juntos
        </h2>
        <p class="font-mono text-gray-400 mb-10 text-lg">
          Cuéntanos sobre tu proyecto y te responderemos en menos de 24 horas.
        </p>

        <!-- Contact info -->
        <div class="space-y-6">
          <a href="mailto:hola@elnodo.studio" class="group flex items-center gap-4">
            <div class="w-12 h-12 rounded-full border border-gray-700 group-hover:border-primary flex items-center justify-center transition-colors duration-300">
              <svg class="w-5 h-5 text-gray-400 group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <span class="font-mono text-xs text-gray-500 block">Email</span>
              <span class="text-light group-hover:text-primary transition-colors">hola@elnodo.studio</span>
            </div>
          </a>

          <a href="https://elnodo.studio" target="_blank" class="group flex items-center gap-4">
            <div class="w-12 h-12 rounded-full border border-gray-700 group-hover:border-primary flex items-center justify-center transition-colors duration-300">
              <svg class="w-5 h-5 text-gray-400 group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
            </div>
            <div>
              <span class="font-mono text-xs text-gray-500 block">Web</span>
              <span class="text-light group-hover:text-primary transition-colors">elnodo.studio</span>
            </div>
          </a>
        </div>
      </div>

      <!-- Contact form -->
      <div class="p-8 md:p-10 rounded-2xl border border-gray-800 bg-gray-900/30 backdrop-blur-sm">
        <form class="space-y-6">
          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="font-mono text-xs text-gray-400 mb-2 block">Nombre</label>
              <input 
                type="text" 
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-lg bg-dark border border-gray-700 text-light placeholder-gray-500 focus:outline-none focus:border-primary transition-colors"
                placeholder="Tu nombre"
              />
            </div>
            <div>
              <label for="email" class="font-mono text-xs text-gray-400 mb-2 block">Email</label>
              <input 
                type="email" 
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-lg bg-dark border border-gray-700 text-light placeholder-gray-500 focus:outline-none focus:border-primary transition-colors"
                placeholder="tu@email.com"
              />
            </div>
          </div>

          <div>
            <label for="service" class="font-mono text-xs text-gray-400 mb-2 block">Servicio</label>
            <select 
              id="service"
              name="service"
              class="w-full px-4 py-3 rounded-lg bg-dark border border-gray-700 text-light focus:outline-none focus:border-primary transition-colors appearance-none cursor-pointer"
            >
              <option value="">Selecciona un servicio</option>
              <option value="web-design">Diseño Web</option>
              <option value="web-dev">Desarrollo Web</option>
              <option value="branding">Branding Digital</option>
              <option value="consulting">Consultoría</option>
            </select>
          </div>

          <div>
            <label for="message" class="font-mono text-xs text-gray-400 mb-2 block">Mensaje</label>
            <textarea 
              id="message"
              name="message"
              rows="4"
              required
              class="w-full px-4 py-3 rounded-lg bg-dark border border-gray-700 text-light placeholder-gray-500 focus:outline-none focus:border-primary transition-colors resize-none"
              placeholder="Cuéntanos sobre tu proyecto..."
            ></textarea>
          </div>

          <button type="submit" class="w-full btn-primary">
            Enviar mensaje
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
