---

<footer class="border-t border-gray-800">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-24 py-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-6">
          <img 
            src="https://hebbkx1anhila5yf.public.blob.vercel-storage.com/B24BBEC4-1ADA-4F89-A389-A0A404EC66D9-F96bhzUjbVSgn8FAudTZGttxeA9TNX.png" 
            alt="elnodo icon" 
            class="w-10 h-10"
          />
          <span class="text-2xl font-bold tracking-tight">
            el<span class="text-primary">nodo</span>
          </span>
        </a>
        <p class="font-mono text-gray-400 text-sm max-w-sm mb-6">
          Diseñamos y desarrollamos experiencias digitales que conectan marcas con personas.
        </p>
        
        <!-- Social links -->
        <div class="flex gap-4">
          {socialLinks.map((social) => (
            <a 
              href={social.href} 
              aria-label={social.name}
              class="w-10 h-10 rounded-full border border-gray-700 hover:border-primary flex items-center justify-center transition-colors duration-300 group"
            >
              <svg class="w-4 h-4 text-gray-400 group-hover:text-primary transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Links -->
      <div>
        <h4 class="font-bold mb-6">Enlaces</h4>
        <ul class="space-y-3">
          <li><a href="#servicios" class="font-mono text-sm text-gray-400 hover:text-primary transition-colors">Servicios</a></li>
          <li><a href="#proyectos" class="font-mono text-sm text-gray-400 hover:text-primary transition-colors">Proyectos</a></li>
          <li><a href="#proceso" class="font-mono text-sm text-gray-400 hover:text-primary transition-colors">Proceso</a></li>
          <li><a href="#contacto" class="font-mono text-sm text-gray-400 hover:text-primary transition-colors">Contacto</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-bold mb-6">Contacto</h4>
        <ul class="space-y-3">
          <li>
            <a href="mailto:hola@elnodo.studio" class="font-mono text-sm text-gray-400 hover:text-primary transition-colors">
              hola@elnodo.studio
            </a>
          </li>
          <li>
            <a href="https://elnodo.studio" target="_blank" class="font-mono text-sm text-gray-400 hover:text-primary transition-colors">
              elnodo.studio
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-gray-800 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="font-mono text-xs text-gray-500">
        &copy; {currentYear} elnodo. Todos los derechos reservados.
      </p>
      <p class="font-mono text-xs text-gray-500">
        Diseñado y desarrollado con <span class="text-primary">pasión</span>
      </p>
    </div>
  </div>
</footer>
