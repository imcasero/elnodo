---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background Effects -->
  <div class="absolute inset-0">
    <!-- Gradient orbs -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/10 rounded-full blur-3xl animate-pulse-glow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-primary/5 rounded-full blur-3xl animate-pulse-glow animation-delay-200"></div>
    
    <!-- Grid pattern -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(228,241,1,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(228,241,1,0.03)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
  </div>

  <div class="relative z-10 section-padding text-center max-w-6xl mx-auto">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-gray-800 bg-gray-900/50 backdrop-blur-sm mb-8 opacity-0 animate-slide-up">
      <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
      <span class="font-mono text-xs text-gray-400">Disponibles para proyectos</span>
    </div>

    <!-- Main Heading -->
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold leading-tight mb-8 opacity-0 animate-slide-up animation-delay-200">
      Diseñamos y desarrollamos
      <br />
      <span class="text-primary text-glow">experiencias digitales</span>
      <br />
      que conectan
    </h1>

    <!-- Subheading -->
    <p class="font-mono text-gray-400 text-lg md:text-xl max-w-2xl mx-auto mb-12 opacity-0 animate-slide-up animation-delay-400">
      Somos una agencia creativa especializada en diseño web y desarrollo. 
      Transformamos ideas en productos digitales excepcionales.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 opacity-0 animate-slide-up animation-delay-600">
      <a href="#proyectos" class="btn-primary">
        Ver proyectos
      </a>
      <a href="#contacto" class="btn-outline">
        Iniciar proyecto
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
      <span class="font-mono text-xs text-gray-500">scroll</span>
      <div class="w-px h-16 bg-gradient-to-b from-primary to-transparent"></div>
    </div>
  </div>

  <!-- Floating icon -->
  <div class="absolute right-12 top-1/2 -translate-y-1/2 hidden lg:block animate-float">
    <img 
      src="https://hebbkx1anhila5yf.public.blob.vercel-storage.com/6455A959-862B-428E-9133-D479FDD5CD45-jVqHebE63qMevBlbWWcFD0ZOc7bWbB.png" 
      alt="elnodo design element" 
      class="w-32 h-32 opacity-20"
    />
  </div>
</section>
